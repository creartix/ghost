{{!< default}}

<section aria-labelledby="hero-heading" class="max-w-5xl mx-auto px-8 py-20 text-center">
    <h1 id="hero-heading" class="font-headline font-light leading-snug text-3xl text-black md:text-4xl dark:text-white">
        <span class="font-semibold">Hey, willkommen bei NaturalRootines.</span> Wir bringen dich in Bewegung mit
        <span class="font-semibold">inspirierenden Artikeln</span> zu Fitness, Gesundheit, Mindset und für mehr Drive und Motivation im Alltag.
    </h1>
</section>

<section class="my-12 px-6">

    <div class="max-w-8xl mx-auto">

        {{!-- Hero Section: Only on page 1 --}}
        {{#unless pagination.prev}}
        <section aria-labelledby="featured-posts-heading" class="mb-16">
            <h2 id="featured-posts-heading" class="sr-only">Aktuelle Artikel</h2>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
                {{!-- First Article - Large (left) --}}
                <div class="lg:col-span-2">
                    {{#foreach posts from="1" to="1"}}
                        <article class="group/article h-full">
                            {{#if feature_image}}
                                <a class="block relative aspect-[16/10] rounded-3xl overflow-hidden group-hover/article:-translate-y-1.5 transition ease duration-400 mb-6" href="{{url}}">
                                    <img
                                        class="w-full h-full object-cover"
                                        srcset="{{img_url feature_image size="m" absolute="true"}} 600w,
                                        {{img_url feature_image size="l" absolute="true"}} 1200w,
                                        {{img_url feature_image size="xl" absolute="true"}} 2000w"
                                        sizes="(max-width: 1024px) 100vw, 66vw"
                                        src="{{img_url feature_image size="l" absolute="true"}}"
                                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                                        loading="eager"
                                        fetchpriority="high"
                                        width="1200"
                                        height="750"
                                    />
                                    {{#if featured}}
                                        <span class="absolute top-4 left-4 bg-yellow-500 px-3 py-2 text-white text-xs inline-flex items-center gap-2 font-semibold rounded-full">
                                            <svg class="w-4 h-auto" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="16" height="16">
                                                <path fill="#ffffff" d="M354.773,61.867c-16.789-14.229-34.389-29.184-52.309-45.483C288.717,3.882,270.151-1.912,251.733,0.555c-17.848,2.358-33.728,12.517-43.349,27.733c-25.43,42.496-43.41,89.025-53.163,137.579c-3.827-5.526-7.222-11.338-10.155-17.387c-10.104-21.288-35.552-30.355-56.84-20.251c-5.154,2.446-9.765,5.901-13.56,10.16c-35.783,36.566-55.62,85.821-55.168,136.981c-1.017,107.532,71.314,201.943,175.403,228.95c19.367,4.873,39.251,7.394,59.221,7.509c0.64,0,7.445-0.064,10.197-0.256c127.36-4.125,228.426-108.648,228.267-236.075C492.501,178.859,428.672,124.672,354.773,61.867z M253.589,469.013c-15.877-1.208-31.567-7.639-43.413-17.195c-18.55-13.126-30.825-32.374-33.749-54.549c-3.627-34.603,17.707-79.851,61.291-130.965l0,0c4.57-5.338,11.256-8.397,18.283-8.363l0,0c6.936-0.05,13.532,3.001,17.984,8.32c39.936,47.403,61.867,91.136,61.867,123.157c-0.123,42.07-33.006,75.35-74.88,79.403C259.133,468.999,256,469.269,253.589,469.013z M374.955,428.437c-1.259,0.981-2.645,1.771-3.925,2.709c4.922-13.378,7.457-27.516,7.488-41.771c0-53.909-39.147-111.68-71.957-150.656c-12.553-14.867-31.017-23.451-50.475-23.467H256c-19.497-0.035-38.028,8.49-50.688,23.317l0,0c-52.16,61.099-76.117,115.989-71.211,163.157c1.165,10.95,3.962,21.664,8.299,31.787c-50.658-36.706-80.507-95.587-80.171-158.144c-0.412-40.639,15.614-79.721,44.437-108.373c4.921,10.23,10.83,19.954,17.643,29.035c9.357,12.65,25.342,18.52,40.661,14.933c15.619-3.455,27.746-15.774,30.955-31.445c8.571-45.304,24.95-88.774,48.405-128.469c2.886-4.538,7.653-7.544,12.992-8.192c5.967-0.803,11.982,1.08,16.427,5.141c18.304,16.64,36.267,32,53.333,46.443c71.211,60.48,122.688,104.171,122.688,181.056c0.184,59.833-27.436,116.358-74.752,152.981L374.955,428.437z" />
                                            </svg> Featured
                                        </span>
                                    {{/if}}
                                </a>
                            {{/if}}

                            <div class="space-y-4">
                                {{#if tags}}
                                    <div class="flex flex-wrap gap-2">
                                        {{#foreach tags limit="3"}}
                                            <a href="{{url}}" class="text-xs px-3 py-1.5 rounded-full bg-neutral-100 text-neutral-600 hover:bg-neutral-200 hover:text-neutral-800 transition ease duration-300 dark:bg-neutral-600 dark:text-neutral-100">{{name}}</a>
                                        {{/foreach}}
                                    </div>
                                {{/if}}

                                <a href="{{url}}" lang="de" class="block font-headline font-semibold text-black hyphens-auto hover:underline hover:underline-offset-4 text-3xl md:text-5xl dark:text-white">
                                    <h2>{{title}}</h2>
                                </a>

                                <p class="lg:text-lg text-neutral-700 dark:text-neutral-300">{{excerpt}}</p>

                                <div class="text-sm text-neutral-600 dark:text-neutral-500">
                                    <time datetime="{{date format="DD.MM.YYYY"}}">
                                        {{date format="D. MMM YYYY"}}
                                    </time>
                                    <span class="bull">&bull;</span>
                                    {{reading_time minute="1 Minute" minutes="% Minuten"}}
                                </div>
                            </div>
                        </article>
                    {{/foreach}}
                </div>

                {{!-- Articles 2 and 3 - Smaller (right) --}}
                <div class="@container">
                    <div class="lg:col-span-1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-10">
                        {{#foreach posts from="2" to="3"}}
                            <article class="group/article">
                                {{#if feature_image}}
                                    <a class="block relative aspect-video rounded-2xl overflow-hidden group-hover/article:-translate-y-1 transition ease duration-400 mb-4" href="{{url}}">
                                        <img
                                            class="w-full h-full object-cover"
                                            srcset="{{img_url feature_image size="s" absolute="true"}} 300w,
                                            {{img_url feature_image size="m" absolute="true"}} 600w"
                                            sizes="(max-width: 1024px) 100vw, 33vw"
                                            src="{{img_url feature_image size="m" absolute="true"}}"
                                            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                                            loading="eager"
                                            width="600"
                                            height="450"
                                        />
                                        {{#if featured}}
                                            <span class="absolute top-3 left-3 bg-yellow-500 px-2 py-1.5 text-white text-xs inline-flex items-center gap-1.5 font-semibold rounded-full">
                                                <svg class="w-3 h-auto" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="12" height="12">
                                                    <path fill="#ffffff" d="M354.773,61.867c-16.789-14.229-34.389-29.184-52.309-45.483C288.717,3.882,270.151-1.912,251.733,0.555c-17.848,2.358-33.728,12.517-43.349,27.733c-25.43,42.496-43.41,89.025-53.163,137.579c-3.827-5.526-7.222-11.338-10.155-17.387c-10.104-21.288-35.552-30.355-56.84-20.251c-5.154,2.446-9.765,5.901-13.56,10.16c-35.783,36.566-55.62,85.821-55.168,136.981c-1.017,107.532,71.314,201.943,175.403,228.95c19.367,4.873,39.251,7.394,59.221,7.509c0.64,0,7.445-0.064,10.197-0.256c127.36-4.125,228.426-108.648,228.267-236.075C492.501,178.859,428.672,124.672,354.773,61.867z M253.589,469.013c-15.877-1.208-31.567-7.639-43.413-17.195c-18.55-13.126-30.825-32.374-33.749-54.549c-3.627-34.603,17.707-79.851,61.291-130.965l0,0c4.57-5.338,11.256-8.397,18.283-8.363l0,0c6.936-0.05,13.532,3.001,17.984,8.32c39.936,47.403,61.867,91.136,61.867,123.157c-0.123,42.07-33.006,75.35-74.88,79.403C259.133,468.999,256,469.269,253.589,469.013z M374.955,428.437c-1.259,0.981-2.645,1.771-3.925,2.709c4.922-13.378,7.457-27.516,7.488-41.771c0-53.909-39.147-111.68-71.957-150.656c-12.553-14.867-31.017-23.451-50.475-23.467H256c-19.497-0.035-38.028,8.49-50.688,23.317l0,0c-52.16,61.099-76.117,115.989-71.211,163.157c1.165,10.95,3.962,21.664,8.299,31.787c-50.658-36.706-80.507-95.587-80.171-158.144c-0.412-40.639,15.614-79.721,44.437-108.373c4.921,10.23,10.83,19.954,17.643,29.035c9.357,12.65,25.342,18.52,40.661,14.933c15.619-3.455,27.746-15.774,30.955-31.445c8.571-45.304,24.95-88.774,48.405-128.469c2.886-4.538,7.653-7.544,12.992-8.192c5.967-0.803,11.982,1.08,16.427,5.141c18.304,16.64,36.267,32,53.333,46.443c71.211,60.48,122.688,104.171,122.688,181.056c0.184,59.833-27.436,116.358-74.752,152.981L374.955,428.437z" />
                                                </svg> Featured
                                            </span>
                                        {{/if}}
                                    </a>
                                {{/if}}
                                <div class="space-y-2">
                                    {{#if tags}}
                                        <div class="flex flex-wrap gap-2">
                                            {{#foreach tags limit="2"}}
                                                <a href="{{url}}" class="text-xs px-2.5 py-1 rounded-full bg-neutral-100 text-neutral-600 hover:bg-neutral-200 hover:text-neutral-800 transition ease duration-300 dark:bg-neutral-600 dark:text-neutral-100">{{name}}</a>
                                            {{/foreach}}
                                        </div>
                                    {{/if}}

                                    <a href="{{url}}" lang="de" class="block font-headline font-semibold text-black hyphens-auto hover:underline hover:underline-offset-4 text-3xl lg:text-2xl dark:text-white">
                                        <h3>{{title}}</h3>
                                    </a>

                                    <p class="lg:line-clamp-3">{{excerpt}}</p>

                                    <div class="text-sm text-neutral-600 dark:text-neutral-500">
                                        <time datetime="{{date format="DD.MM.YYYY"}}">
                                            {{date format="D. MMM YYYY"}}
                                        </time>
                                        <span class="bull">&bull;</span>
                                        {{reading_time minute="1 Min" minutes="% Min"}}
                                    </div>
                                </div>
                            </article>
                        {{/foreach}}
                    </div>
                </div>
            </div>
        </section>

        {{!-- Tags Section --}}
        <section aria-labelledby="topics-heading" class="mb-16">
            <h2 id="topics-heading" class="mb-6 font-medium uppercase text-xs dark:text-neutral-400">Themenbereiche</h2>
            <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-6">
                {{#get "tags" limit="6"}}
                {{#foreach tags}}
                    <a href="{{url}}"
                        class="relative aspect-article overflow-hidden rounded-2xl hover:-translate-y-1 transition ease duration-400">
                        <img class="w-full h-full object-cover" src="{{img_url feature_image size="m" absolute="true"}}" alt="{{name}}" loading="lazy" width="600" height="375" />
                        <div class="py-2 px-3 backdrop-blur-md absolute bottom-3 left-3 z-10 rounded-full{{#unless accent_color}} bg-white/40{{/unless}}"{{#if accent_color}} style="background-color: {{accent_color}}60;"{{/if}}>
                            <h3 class="text-xs font-semibold text-black">{{name}}</h3>
                        </div>
                    </a>
                {{/foreach}}
                {{/get}}
            </div>
        </section>
        {{/unless}}

        {{!-- All Other Articles (starting from 4th on page 1, all on other pages) --}}
        <section aria-labelledby="all-posts-heading">
            <h2 id="all-posts-heading" class="mb-6 font-medium uppercase text-xs dark:text-neutral-400">Alle Beiträge</h2>
            <div class="gh-postfeed @container grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
                {{#unless pagination.prev}}
                    {{#foreach posts from="4"}}
                        {{> "post-card" page=../pagination.page}}
                    {{/foreach}}
                {{else}}
                    {{#foreach posts}}
                        {{> "post-card" page=../pagination.page}}
                    {{/foreach}}
                {{/unless}}
            </div>
            {{#if pagination.next}}
                <div class="flex justify-center mt-12">
                    <button id="load-more-btn" data-next-url="{{@site.url}}/page/{{pagination.next}}/" class="px-8 py-3 rounded-full border-2 border-black text-black font-semibold hover:bg-black hover:text-white transition dark:border-white dark:text-white dark:hover:bg-white dark:hover:text-black">
                        Mehr laden
                    </button>
                </div>
            {{/if}}
        </section>

        <noscript>
            <div class="gh-pagination">
                {{pagination}}
            </div>
        </noscript>

    </div>

</section>