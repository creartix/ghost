{
    "name": "naturalrootines",
    "description": "",
    "version": "1.0.0",
    "engines": {
        "ghost": ">=5.0.0"
    },
    "license": "MIT",
    "screenshots": {
        "desktop": "assets/screenshot-desktop.jpg"
    },
    "scripts": {
        "dev": "concurrently \"vite build --watch --mode development\" \"browser-sync start --proxy 'localhost:2368' --files 'assets/built/main.css,assets/built/app.js' --port 3000 --no-open\"",
        "build": "vite build",
        "watch": "vite build --watch"
    },
    "author": {
        "name": "NaturalRootines",
        "email": "hello@naturalrootines.de",
        "url": "https://naturalrootines.de"
    },
    "gpm": {
        "type": "theme",
        "categories": [
            "Minimal",
            "Magazine"
        ]
    },
    "keywords": [
        "ghost",
        "theme",
        "ghost-theme"
    ],
    "repository": {
        "type": "git",
        "url": ""
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.3.1",
        "@tailwindcss/postcss": "^4.3.1",
        "@tailwindcss/typography": "^0.5.20",
        "bestzip": "^3.0.1",
        "browser-sync": "^3.0.4",
        "concurrently": "^10.0.3",
        "tailwindcss": "^4.3.1",
        "vite": "^8.1.0"
    },
    "browserslist": [
        "defaults"
    ],
    "config": {
        "card_assets": true,
        "posts_per_page": 12,
        "image_sizes": {
            "xxs": {
                "width": 30
            },
            "xs": {
                "width": 100
            },
            "s": {
                "width": 300
            },
            "m": {
                "width": 600
            },
            "l": {
                "width": 1200
            },
            "xl": {
                "width": 2000
            }
        },
        "custom_theme_settings": [],
        "portal": {
            "button": true,
            "name": true,
            "plans": [
                "free",
                "monthly",
                "yearly"
            ],
            "default": "free"
        }
    },
    "type": "module",
    "dependencies": {
        "caniuse-lite": "^1.0.30001751"
    }
}
