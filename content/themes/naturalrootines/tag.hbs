{{!< default}}

{{#tag}}
    <div class="h-[30vh] lg:h-[50vh] opacity-30 absolute top-0 left-0 right-0 -z-1 mask-cover mask-no-repeat [mask-image:linear-gradient(to_top,transparent_0%,rgba(0,0,0,0.25)_40%,rgba(0,0,0,0.75)_70%,black_100%)]">
        <img
            class="w-full h-full object-cover"
            srcset="{{img_url feature_image size="s"}} 300w,
            {{img_url feature_image size="m" }} 600w,
            {{img_url feature_image size="l" }} 1200w,
            {{img_url feature_image size="xl" }} 2000w"
            sizes="100vw"
            src="{{img_url feature_image size="l"}}"
            alt="{{name}}"
            loading="eager"
            fetchpriority="high"
            width="1200"
            height="600"
        />
    </div>

    <div class="max-w-5xl mx-auto px-8 py-12 text-center" itemscope itemtype="https://schema.org/CollectionPage">
        <h1 class="font-headline font-light text-3xl text-black leading-tight lg:text-5xl dark:text-white" itemprop="name">
            <span class="font-semibold">{{name}}</span>
        </h1>
        <p class="mt-4 font-headline font-light text-xl text-neutral-800 lg:text-2xl dark:text-neutral-100" itemprop="description">
            {{#if description}}
                {{description}}
            {{else}}
                Eine Sammlung von {{plural ../pagination.total empty='Beiträgen' singular='% Beitrag' plural='% Beiträgen'}}
            {{/if}}
        </p>
        <meta itemprop="url" content="{{url absolute="true"}}">
    </div>
{{/tag}}

<section class="py-16 px-6">
    <div class="max-w-8xl mx-auto">
        <section>
            <h2 class="mb-4 font-medium uppercase text-xs dark:text-neutral-400">
                {{#tag}}
                {{plural ../pagination.total empty='Beiträgen' singular='% Beitrag' plural='% Beiträge'}} über {{name}}
                {{/tag}}
            </h2>
            <div class="@container grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
                {{#foreach posts}}
                    {{> "post-card"}}
                {{/foreach}}
            </div>
        </section>

        {{!-- Related Tags for Topic Clustering --}}
        {{#tag}}
            {{#get "tags" limit="6" filter="slug:-{{slug}}" as |related_tags|}}
                {{#if related_tags}}
                    <section class="mt-16 pt-12 border-t border-neutral-200 dark:border-neutral-700">
                        <h2 class="mb-6 font-headline font-semibold text-2xl text-black dark:text-white">Weitere Themen</h2>
                        <div class="flex flex-wrap gap-3">
                            {{#foreach related_tags}}
                                <a href="{{url}}" class="px-4 py-2 rounded-full bg-neutral-100 font-semibold text-neutral-600 hover:bg-neutral-200 hover:text-neutral-800 transition ease duration-300 dark:bg-neutral-600 dark:text-neutral-100 active:scale-[.98]">
                                    {{name}}
                                </a>
                            {{/foreach}}
                        </div>
                    </section>
                {{/if}}
            {{/get}}
        {{/tag}}
    </div>
</section>

