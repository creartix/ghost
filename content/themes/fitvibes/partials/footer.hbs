<footer class="bg-neutral-50 dark:bg-black px-8">

    <div class="mx-auto max-w-8xl py-12 border-b border-neutral-200 dark:border-white/20">
        <div class="grid grid-cols-1 md:grid-cols-12 md:items-center gap-4 md:gap-8">
            <div class="md:col-span-6">
                <div class="mb-2 text-neutral-500 dark:text-neutral-300 text-xs uppercase">Newsletter</div>
                <div class="font-headline text-4xl font-bold mb-3 text-black dark:text-white">Bleib auf dem Laufenden!
                </div>
                <p>Erhalte die neuesten Tipps zu Fitness, Gesundheit, Supplements und Mindset direkt in dein Postfach – für mehr Energie, Balance und Wohlbefinden in deinem Alltag!</p>
            </div>
            <div class="md:col-span-6">
                <form data-members-form="subscribe" class="flex flex-col gap-5 xl:flex-row">
                    <input
                        class="bg-white flex-1 px-6 py-4 border border-neutral-200 rounded-full text-sm text-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary dark:placeholder:text-neutral-400 dark:border-neutral-700 dark:bg-neutral-700 transition-all ease-in-out duration-500"
                        type="email" data-members-email placeholder="Deine E-Mail-Adresse" required />
                    <button type="submit"
                        class="bg-primary inline-flex justify-center items-center cursor-pointer gap-2 px-6 py-3 text-white font-semibold rounded-full group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary active:scale-[.98] transition-all">
                        Anmelden
                        <svg xmlns="http://www.w3.org/2000/svg" id="Outline" viewBox="0 0 24 24" width="20" height="20" class="group-hover:translate-x-1 transition-transform duration-300">
                            <path class="fill-white" d="M18,12h0a2,2,0,0,0-.59-1.4l-4.29-4.3a1,1,0,0,0-1.41,0,1,1,0,0,0,0,1.42L15,11H5a1,1,0,0,0,0,2H15l-3.29,3.29a1,1,0,0,0,1.41,1.42l4.29-4.3A2,2,0,0,0,18,12Z" />
                        </svg>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="mx-auto max-w-8xl py-12 border-b border-neutral-200 dark:border-white/20">
        <div class="grid grid-cols-1 md:grid-cols-12 md:items-center gap-4 md:gap-8">
            <div class="text-center space-y-2 md:text-left md:col-span-6">
                <a href="{{@site.url}}">
                    <svg class="w-auto h-12 fill-black dark:fill-white" width="1600" height="400" viewBox="0 0 1600 400"
                        xmlns="http://www.w3.org/2000/svg">
                        <text x="50%" y="62%" text-anchor="middle"
                            font-family="Avenir Next, Nunito Sans, Montserrat, Poppins, Arial, sans-serif" font-size="180"
                            font-weight="800" letter-spacing="-6" fill="current">NaturalRootines</text>
                    </svg>
                </a>
                <p class="text-sm/6 text-balance text-neutral-600 dark:text-neutral-400">
                    {{@site.description}}
                </p>
            </div>
            <div class="md:col-span-6 flex justify-center items-center gap-3 md:justify-end">
                <a href="https://twitter.com/" target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-neutral-100 cursor-pointer text-black font-semibold text-xs rounded-full hover:bg-neutral-200 transition dark:bg-white dark:text-black dark:hover:bg-neutral-200">
                    <svg class="size-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                    </svg>
                </a>
